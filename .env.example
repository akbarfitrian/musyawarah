# Copy this file to .env.local and fill in your Supabase project values
# Get these from: Supabase Dashboard -> Project Settings -> API
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Sphere wallet (Unicity Labs) — dipakai buat mode popup (P3) kalau user
# nggak punya Sphere extension dan app ini nggak jalan di dalam iframe Sphere.
# Default udah mengarah ke wallet production, biasanya nggak perlu diubah
# kecuali lagi develop lokal lawan Sphere wallet yang jalan di localhost:5173.
VITE_SPHERE_WALLET_URL=https://sphere.unicity.network

# Opsional: isi ini KALAU resolveUctCoin() di WalletContext.tsx gagal nemuin
# coinId UCT otomatis dari wallet (lihat komentar di file itu). Formatnya
# 64-hex huruf kecil sesuai protocol reference Sphere Connect.
# VITE_SPHERE_UCT_COIN_ID=

# Wallet treasury platform -- tujuan pembayaran waktu user beli tier
# verifikasi (Verified / Verified Pro / Verified Max) di halaman "Get
# Verified". Pembayarannya lewat sendTip() yang sama dipakai buat tip biasa
# (lihat src/hooks/useVerification.ts). WAJIB diisi sebelum fitur ini bisa
# dipakai -- kalau kosong, tombol beli akan gagal dengan pesan error yang
# jelas alih-alih diam-diam kirim ke alamat yang salah.
VITE_VERIFICATION_TREASURY_WALLET=
